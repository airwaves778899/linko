# =========================================================
# Linko 環境變數範本
# 複製此檔為 .env 後填入實際金鑰：cp .env.example .env
# =========================================================

# --- LINE 設定（必填）---
# 從 LINE Developers Console > 你的 Provider > Messaging API Channel 取得
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- AI 模型金鑰（至少填一個，與 config.yaml 的 ai.provider 對應）---
# 你想用哪個 provider，就填它對應的 key 即可，其他留空。
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- 本地 LM Studio（可選）---
# 在 LM Studio 內按「Developer」→「Start Server」後，預設位址是 http://localhost:1234/v1
# API Key 隨便填一個非空字串即可（LM Studio 本身不驗證，但 LiteLLM 需要看到值）
# LM_STUDIO_API_BASE=http://localhost:1234/v1
# LM_STUDIO_API_KEY=lm-studio

# --- 本地 Ollama（可選）---
# OLLAMA_API_BASE=http://localhost:11434

# --- 伺服器設定（可選，有預設值）---
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
